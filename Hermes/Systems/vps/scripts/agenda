#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PY="$SCRIPT_DIR/agenda.py"
cmd="${1:-today}"
shift || true
case "$cmd" in
  hoy|today)
    exec python3 "$PY" today "$@"
    ;;
  mañana|manana|tomorrow)
    exec python3 "$PY" tomorrow "$@"
    ;;
  listar|list)
    exec python3 "$PY" list "$@"
    ;;
  crear|ensure)
    exec python3 "$PY" ensure "$@"
    ;;
  agregar|add)
    exec python3 "$PY" add "$@"
    ;;
  hecho|done)
    exec python3 "$PY" done "$@"
    ;;
  posponer|snooze)
    exec python3 "$PY" snooze "$@"
    ;;
  foco|focus)
    exec python3 "$PY" focus "$@"
    ;;
  recordatorios|reminders)
    exec python3 "$PY" reminders "$@"
    ;;
  *)
    exec python3 "$PY" "$cmd" "$@"
    ;;
esac
